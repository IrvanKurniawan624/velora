# Velora zero-api-local agent — environment variables
# The submitted container reads these purely from the environment (no .env in
# the image); the harness injects the real values at eval time. For local dev,
# copy this file to .env and adjust.

# ---- Mode ----
# zero   = never call Fireworks (0 scored tokens) — the submission default.
# hybrid = escalate only independently-unverifiable low-confidence tasks to
#          Fireworks (escape hatch; still reads FIREWORKS_* / ALLOWED_MODELS).
MODE=zero

# ---- Local llama-server ----
# In the container these are set by the Dockerfile. For local dev, point them
# at your own llama-server binary + GGUF weights (see eval/run_local.py).
LLAMA_BIN=/opt/llama/llama-server
MODEL_PATH=/models/model.gguf
LLAMA_THREADS=2
LLAMA_CTX=4096
LLAMA_PORT=8091
# Set LLAMA_URL to reuse an already-running llama-server (skips subprocess spawn).
# LLAMA_URL=http://127.0.0.1:8091

# ---- Wall-clock budgets (seconds); watchdog flushes + exits at HARD_DEADLINE ----
SOFT_DEADLINE=500
HARD_DEADLINE=560

# ---- Hybrid-mode escalation (ignored in MODE=zero) ----
ESC_MAX=6
ESC_CONF=0.55
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/minimax-m3,accounts/fireworks/models/kimi-k2p7-code
# Local-dev only (e.g. Avast MITMs HTTPS with a cert OpenSSL rejects): set to 1
# to skip SSL verification. Never set this on the judge VM.
# FW_INSECURE_SSL=1
