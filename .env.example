# --- Original Velora Config (DO NOT REMOVE) ---
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=
EP_COMPLETION_PARAMS='[{"model": "<Your model here>"}]'

# --- JIT Router Config (added by @arya) ---
# Fireworks premium model (digunakan untuk eskalasi dari model lokal)
FIREWORKS_MODEL=accounts/fireworks/models/qwen3-30b-a3b

# LM Studio local server (pastikan LM Studio berjalan dan model sudah di-load)
# Sesuaikan LMSTUDIO_MODEL_3B dan LMSTUDIO_MODEL_7B dengan nama model
# yang ada di LM Studio Anda masing-masing.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL_3B=qwen3-3b
LMSTUDIO_MODEL_7B=qwen3-7b

# Router thresholds (bisa di-tune per environment)
CONFIDENCE_THRESHOLD=0.7
JIT_COST_LAMBDA=0.3
